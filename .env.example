# Point at the RATES Supabase project (the one with geocode_cache + us_ports).
SUPABASE_URL=https://your-rates-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only; never NEXT_PUBLIC_*
CONTACT_EMAIL=you@example.com

# HERE Routing v8 — truck (drayage) routes.
HERE_API_KEY=your-here-api-key                     # server-only; never NEXT_PUBLIC_*

# Optional overrides (defaults shown)
# NOMINATIM_URL=https://nominatim.openstreetmap.org/search
# NOMINATIM_MIN_INTERVAL=1.0
# NOMINATIM_TIMEOUT=10.0
# NOMINATIM_COUNTRY_CODES=us
# HERE_API_URL=https://router.hereapi.com/v8/routes
# HERE_MIN_INTERVAL=0.5
# HERE_TIMEOUT=15.0
# Truck profile — HERE v8 units: dimensions in CM, weight in KG.
# TRUCK_HEIGHT_CM=400
# TRUCK_WIDTH_CM=300
# TRUCK_LENGTH_CM=1600
# TRUCK_WEIGHT_KG=36000
